{
  "permissions": {
    "allow": [
      "Bash(./scripts/skill-context.sh:*)",
      "Bash(git *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-git-policy.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
